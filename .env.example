# Copie este arquivo para .env e preencha os valores antes de executar a aplicação
# Nunca versione o arquivo .env no repositório!

# Chave secreta para sessões Flask (use uma string longa e aleatória em produção)
SECRET_KEY=troque-por-uma-chave-secreta-segura

# URI do banco de dados (padrão: SQLite local)
DATABASE_URI=sqlite:///ecosmart.db
